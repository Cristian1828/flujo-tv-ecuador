---
import { site } from '../config/site';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle    = 'Términos y Condiciones de Uso | Flujo TV Oficial 2026';
const pageDesc     = 'Términos y condiciones del servicio Flujo TV: compatibilidad de dispositivos (Android TV, Google TV, Fire Stick, TV Box), planes de suscripción, activación, soporte técnico y uso permitido.';
const pageKeywords = 'terminos condiciones Flujo TV, condiciones uso Flujo TV, terminos servicio Flujo TV, reglas Flujo TV, politica uso Flujo TV, dispositivos compatibles Flujo TV, planes Flujo TV condiciones';
const canonical    = `${site.canonical}/terminos`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.canonical },
    { '@type': 'ListItem', position: 2, name: 'Términos y Condiciones', item: canonical },
  ],
};
---

<Layout title={pageTitle} description={pageDesc} keywords={pageKeywords}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <link rel="canonical" href={canonical} slot="head" />
  <Header />

  <main class="pt-28 pb-16 sm:pb-20">
    <section class="mx-auto max-w-4xl px-4">
      <article class="rounded-[2rem] border border-slate-900/10 bg-white/80 shadow-soft p-6 sm:p-10">
        <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-slate-900">Términos y Condiciones</h1>
        <p class="mt-2 text-sm text-slate-900/60">Última actualización: 20 de febrero de 2026</p>

        <div class="mt-8 space-y-7 text-sm sm:text-base leading-relaxed text-slate-900/75">
          <section>
            <h2 class="text-lg font-black text-slate-900">1. Aceptación del servicio</h2>
            <p class="mt-2">Al contratar Flujo TV, aceptas estos términos y condiciones para activación, soporte y uso del servicio.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">2. Alcance del servicio</h2>
            <p class="mt-2">Flujo TV ofrece acceso a una aplicación de entretenimiento y soporte técnico de activación. El servicio requiere conexión a internet estable para un funcionamiento adecuado.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">3. Compatibilidad de dispositivos</h2>
            <p class="mt-2">El servicio es compatible con Android (celular y tablet), TV Box, Fire Stick, Google TV y Xiaomi Stick. En Smart TV Samsung o LG se utiliza mediante TV Box o Stick externo.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">4. Planes y activación</h2>
            <p class="mt-2">Los planes se activan una vez validado el pago. Cada cuenta permite hasta 3 pantallas simultáneas según condiciones comerciales vigentes.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">5. Activación y soporte</h2>
            <p class="mt-2">Una vez activada la cuenta, ofrecemos activación asegurada y soporte técnico para resolver incidencias de configuración y uso.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">6. Uso permitido</h2>
            <p class="mt-2">El acceso es personal. No está permitido revender, compartir de forma comercial o redistribuir credenciales del servicio.</p>
          </section>

          <section>
            <h2 class="text-lg font-black text-slate-900">7. Contacto</h2>
            <p class="mt-2">Para consultas comerciales o soporte, contáctanos por WhatsApp o correo oficial publicado en esta web.</p>
          </section>
        </div>
      </article>
    </section>
  </main>

  <Footer />
</Layout>
